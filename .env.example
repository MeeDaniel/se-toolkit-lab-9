# ============================================
# TourStats - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Required for deployment.
# ============================================

# --- Database ---
POSTGRES_USER=tourstats
# CHANGE THIS: Use a strong password for production
POSTGRES_PASSWORD=changeme_password_123
POSTGRES_DB=tourstats_db
# Internal Docker URL — do not change unless you know what you're doing
DATABASE_URL=postgresql+asyncpg://tourstats:changeme_password_123@db:5432/tourstats_db

# --- Mistral AI ---
# Get your API key from: https://console.mistral.ai/api-keys/
# Free tier available with generous limits
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# --- Nanobot Agent (WebSocket AI) ---
# CHANGE THIS: Use a strong random string
NANOBOT_ACCESS_KEY=changeme_nanobot_key_123
NANOBOT_WS_URL=ws://nanobot:8000/ws
NANOBOT_SYSTEM_PROMPT=You are a helpful assistant for Innopolis tour guides. Help them analyze excursion data and find insights about tourist demographics and interests.

# --- Backend ---
# Internal Docker URL — do not change
BACKEND_URL=http://backend:8000
# CHANGE THIS: Use a strong random string
BACKEND_SECRET=changeme_backend_secret_123

# --- Caddy Reverse Proxy ---
# For local development: leave as localhost
# For production VM: set to your domain (e.g., tourstats.example.com)
# If no domain, use the VM's public IP address
CADDY_DOMAIN=localhost
# Your email for Let's Encrypt (required if using a real domain)
CADDY_ADMIN_EMAIL=admin@example.com

# --- Frontend (React Client) ---
# For production with Caddy proxy, these should use relative paths.
# The defaults below work automatically when accessed through Caddy.
# Override only if you access the client directly (not through Caddy).
REACT_APP_WS_URL=
REACT_APP_API_URL=
# Must match NANOBOT_ACCESS_KEY above
REACT_APP_NANOBOT_ACCESS_KEY=

# --- OpenTelemetry (Optional, internal use) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=tourstats
