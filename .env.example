# Required Services
POSTGRES_USER=tourstats
POSTGRES_PASSWORD=changeme_password_123
POSTGRES_DB=tourstats_db
DATABASE_URL=postgresql+asyncpg://tourstats:changeme_password_123@db:5432/tourstats_db

# Qwen API Configuration
QWEN_API_KEY=your_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Nanobot Agent
NANOBOT_ACCESS_KEY=changeme_nanobot_key_123
NANOBOT_WS_URL=ws://nanobot:8000/ws
NANOBOT_SYSTEM_PROMPT=You are a helpful assistant for Innopolis tour guides. Help them analyze excursion data and find insights about tourist demographics and interests.

# Backend
BACKEND_URL=http://backend:8000
BACKEND_SECRET=changeme_backend_secret_123

# Caddy Proxy
CADDY_DOMAIN=localhost
CADDY_ADMIN_EMAIL=admin@example.com

# OpenTelemetry (Optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=tourstats
